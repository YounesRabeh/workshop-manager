{
  "name": "workshop-manager",
  "productName": "Workshop Manager",
  "version": "0.9.8",
  "description": "Create and update items for Steam's Workshop.",
  "author": "Younes Rabeh",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller"
    ]
  },
  "main": "out/main/index.js",
  "build": {
    "appId": "com.workshop.manager",
    "productName": "Workshop Manager",
    "directories": {
      "output": "dist"
    },
    "beforeBuild": "./scripts/electron-builder-before-build.mjs",
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "win": {
      "icon": "resources/img/app-icon.ico",
      "target": [
        {
          "target": "nsis"
        }
      ]
    },
    "nsis": {
      "include": "resources/installer.nsh",
      "runAfterFinish": true
    },
    "mac": {
      "icon": "resources/img/app-icon.icns",
      "target": [
        {
          "target": "dmg"
        }
      ]
    },
    "linux": {
      "icon": "resources/img/app-icon.normalized.png",
      "category": "Utility",
      "desktop": {
        "entry": {
          "Name": "Workshop Manager",
          "StartupWMClass": "workshop-manager"
        }
      },
      "target": [
        {
          "target": "AppImage"
        }
      ]
    }
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "kill:instance": "node scripts/kill-old-instance.mjs",
    "predev": "pnpm kill:instance && pnpm sync:icon",
    "dev": "env -u ELECTRON_RUN_AS_NODE CHROME_DESKTOP=workshop-manager.desktop electron-vite dev",
    "sync:icon": "node scripts/sync-app-icon.mjs",
    "build:bundle:native": "electron-vite build",
    "build:bundle": "node scripts/run-build-in-docker.mjs build:bundle:native",
    "build": "node scripts/run-build-in-docker.mjs build:bundle:native",
    "build:exe:native": "node scripts/build-executable.mjs",
    "build:appImage": "node scripts/run-build-in-docker.mjs build:exe:native",
    "build:appImage:icon": "node scripts/run-build-in-docker.mjs build:exe:native --generate-icon",
    "build:win": "node scripts/run-build-in-docker.mjs build:exe:native --win",
    "build:win:icon": "node scripts/run-build-in-docker.mjs build:exe:native --win --generate-icon",
    "prepreview": "pnpm sync:icon",
    "preview": "env -u ELECTRON_RUN_AS_NODE CHROME_DESKTOP=workshop-manager.desktop electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && vue-tsc --noEmit -p tsconfig.renderer.json && vue-tsc --noEmit -p tsconfig.renderer-tests.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.2",
    "@types/node": "^22.13.14",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.2",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.9",
    "vue-tsc": "^2.2.8"
  }
}
