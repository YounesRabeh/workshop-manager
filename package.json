{
  "name": "workshop-manager",
  "productName": "Workshop Manager",
  "version": "0.9.4",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "main": "out/main/index.js",
  "build": {
    "appId": "com.workshop.manager",
    "productName": "Workshop Manager",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "win": {
      "icon": "resources/app-icon.ico",
      "target": [
        {
          "target": "nsis"
        }
      ]
    },
    "mac": {
      "icon": "resources/app-icon.icns",
      "target": [
        {
          "target": "dmg"
        }
      ]
    },
    "linux": {
      "icon": "resources/app-icon.normalized.png",
      "category": "Utility",
      "desktop": {
        "Name": "Workshop Manager",
        "StartupWMClass": "workshop-manager"
      },
      "target": [
        {
          "target": "AppImage"
        }
      ]
    }
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "kill:instance": "node scripts/kill-old-instance.mjs",
    "predev": "pnpm kill:instance && pnpm sync:icon",
    "dev": "CHROME_DESKTOP=workshop-manager.desktop electron-vite dev",
    "sync:icon": "node scripts/sync-app-icon.mjs",
    "prebuild": "pnpm kill:instance",
    "build:bundle": "electron-vite build",
    "build": "pnpm build:bundle",
    "build:exe": "node scripts/build-executable.mjs",
    "build:exe:icon": "node scripts/build-executable.mjs --generate-icon",
    "prepreview": "pnpm sync:icon",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && vue-tsc --noEmit -p tsconfig.renderer.json && vue-tsc --noEmit -p tsconfig.renderer-tests.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.2",
    "@types/node": "^22.13.14",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^3.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.2",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.9",
    "vue-tsc": "^2.2.8"
  }
}
