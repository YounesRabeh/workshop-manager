{
  "extends": "./tsconfig.base.json",
  "include": [
    "electron.vite.config.ts",
    "src/electron/**/*.ts",
    "src/backend/**/*.ts",
    "src/frontend/**/*.d.ts",
    "src/shared/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "test/unit/frontend/app/app-ui.spec.ts",
    "test/unit/frontend/composables/use-auth-flow.spec.ts",
    "test/unit/frontend/composables/use-drafts.spec.ts",
    "test/unit/frontend/composables/use-publish-actions.spec.ts",
    "test/unit/frontend/composables/use-workshop-items.spec.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["node", "vitest"]
  }
}
