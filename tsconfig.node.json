{
  "extends": "./tsconfig.base.json",
  "include": [
    "electron.vite.config.ts",
    "src/electron/**/*.ts",
    "src/backend/**/*.ts",
    "src/frontend/**/*.d.ts",
    "src/shared/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "test/unit/frontend/**/*.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "ignoreDeprecations": "5.0",
    "types": ["node", "vitest"]
  }
}
